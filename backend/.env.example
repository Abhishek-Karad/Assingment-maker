# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/veda-ai

# Server Configuration
PORT=5001
NODE_ENV=production

# AWS S3 Configuration (for file uploads and PDF storage)
USE_S3=true
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-north-1
AWS_S3_BUCKET_NAME=assignment-creator

# Redis Configuration (for Bull MQ - Question Generation Queue)
REDIS_URL=redis://default:password@your-redis-host.railway.app:6379

# Google Gemini API (for Question Generation)
GEMINI_API_KEY=your-gemini-api-key

# Frontend Configuration (for CORS - set to your Vercel domain in production)
FRONTEND_URL=https://your-vercel-domain.vercel.app
