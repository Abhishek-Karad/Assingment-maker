    "express": "^4.18.2",
    "express-validator": "^7.0.0",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.18.0",
    "redis": "^4.6.12",
    "sharp": "^0.32.6",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/bull": "^3.15.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/pdfkit": "^0.17.5",
    "@types/socket.io": "^3.0.1",
